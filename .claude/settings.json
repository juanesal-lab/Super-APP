{
  "permissions": {
    "allow": [
      "Bash(git push:*)",
      "Bash(git pull:*)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/autosave.sh\"",
            "timeout": 45,
            "statusMessage": "Auto-guardando (commit + push)..."
          }
        ]
      }
    ]
  }
}
